# g0efilter configuration

LOG_LEVEL=DEBUG
HOSTNAME=host-01
HTTP_PORT=8080
HTTPS_PORT=8443
POLICY_PATH=/app/policy.yaml

# FILTER_MODE=https # Default

# Dashboard integration
DASHBOARD_HOST=http://localhost:8081
DASHBOARD_API_KEY=your-secure-api-key-here

# Remote unblock (requires auth middleware on dashboard)
ENABLE_REMOTE_UNBLOCK=true # Disabled by default
UNBLOCK_POLL_INTERVAL=2s

# Notifications
# NOTIFICATION_HOST=https://gotify.example.com
# NOTIFICATION_KEY=your-gotify-app-key

# Refer to README.md for more configuration options
